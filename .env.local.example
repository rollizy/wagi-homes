# Copy this file to .env.local and fill in your values

# Supabase - get these from https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Cloudflare R2 CDN base URL for panorama images
NEXT_PUBLIC_CDN_BASE_URL=https://pub-xxxx.r2.dev
